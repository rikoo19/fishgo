{
  "rewrites": [
    { "source": "/frontend", "destination": "/index.html" },
    { "source": "/frontend/", "destination": "/index.html" },
    { "source": "/frontend/index.html", "destination": "/index.html" },
    { "source": "/frontend/game_new.js", "destination": "/frontbundle/game_new.js" },
    { "source": "/frontbundle/:path*", "destination": "/api/index.py" },
    { "source": "/api/:path*", "destination": "/api/index.py" },
    { "source": "/frontend/:path*", "destination": "/api/index.py" }
  ]
}
